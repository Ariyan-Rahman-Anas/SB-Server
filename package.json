{
  "name": "shine-bright-server",
  "version": "1.0.0",
  "description": "Shine Bright e-commerce backend API",
  "main": "api/handler.mjs",
  "engines": {
    "node": ">=20.x"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "node esbuild.mjs",
    "start": "node api/handler.mjs",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "seed:admin": "tsx src/scripts/seed-admin.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@types/multer": "^2.1.0",
    "@types/streamifier": "^0.1.2",
    "better-auth": "^1.6.12",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "http-status-codes": "^2.3.0",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "resend": "^4.1.2",
    "streamifier": "^0.1.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.13.0",
    "esbuild": "^0.28.0",
    "prisma": "^5.22.0",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.7.3"
  }
}
